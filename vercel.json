{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "yarn --cwd frontend install --frozen-lockfile && yarn --cwd frontend build",
  "outputDirectory": "frontend/dist",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/[...path].py"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
